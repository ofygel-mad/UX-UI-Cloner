{
  "name": "@fcb/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Native desktop shell for the Frontend Capture Browser toolchain",
  "author": "OpenAI Codex",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node ./scripts/build-desktop.mjs && electron dist/main.js",
    "build": "node ./scripts/build-desktop.mjs",
    "package:dir": "pnpm run build && electron-builder --dir",
    "package:win": "pnpm run build && electron-builder --win portable",
    "start": "electron dist/main.js"
  },
  "dependencies": {
    "playwright": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "esbuild": "latest",
    "typescript": "latest"
  },
  "build": {
    "appId": "com.fcb.desktop",
    "productName": "Frontend Capture Browser",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
